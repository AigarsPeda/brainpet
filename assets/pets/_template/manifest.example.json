{
  "id": "your-pet-id",
  "name": "Your Pet",
  "species": "cat",
  "promptVersion": "2.0",
  "layout": {
    "type": "grid-v2",
    "sheetCols": 2,
    "sheetRows": 2,
    "frameWidth": 128,
    "frameHeight": 128,
    "gutter": 32,
    "margin": 32
  },
  "sheetSize": { "width": 352, "height": 352 },
  "animations": {
    "idle": { "file": "sheets/idle.png", "frames": 4 },
    "excited": { "file": "sheets/excited.png", "frames": 4 },
    "dancing": { "file": "sheets/dancing.png", "frames": 4 },
    "eating": { "file": "sheets/eating.png", "frames": 4 },
    "angry": { "file": "sheets/angry.png", "frames": 4 },
    "sad": { "file": "sheets/sad.png", "frames": 4 },
    "sleeping": { "file": "sheets/sleeping.png", "frames": 4 }
  },
  "_note": "Copy to manifest.ts with require() for each PNG. See dog/manifest.ts for legacy v1 example."
}
